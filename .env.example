# Telegram
TELEGRAM_BOT_TOKEN=

# Active video provider: veo | runway | kling | seedance
VIDEO_PROVIDER=veo

# Google Veo 3 (Google GenAI)
GOOGLE_API_KEY=

# Runway Gen-3
RUNWAY_API_KEY=

# Kling AI
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# Seedance 2.0 (VolcEngine/Ark)
SEEDANCE_API_KEY=

# Puppeteer (VPS only — use system Chromium instead of bundled)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# Video settings
DEFAULT_VIDEO_QUALITY=1080p
VIDEO_DURATION_SECONDS=8
